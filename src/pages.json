{
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/categories/list/index",
      "style": {
        "navigationBarTitleText": "分类"
      }
    },
    {
      "path": "pages/categories/info/index",
      "style": {
        "navigationBarTitleText": "分类详情"
      }
    },
    {
      "path": "pages/tags/list/index",
      "style": {
        "navigationBarTitleText": "标签"
      }
    },
    {
      "path": "pages/tags/info/index",
      "style": {
        "navigationBarTitleText": "标签详情"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "关于"
      }
    },
    {
      "path": "pages/blogs/index",
      "style": {
        "navigationBarTitleText": "博客列表",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/blog-view/index",
      "style": {
        "navigationBarTitleText": "博客详情",
        "mp-weixin": {
          "usingComponents": {
            "towxml": "/static/towxml/towxml"
          }
        }
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "@navBgColor",
    "backgroundColor": "@bgColor"
  },
  "tabBar": {
    "color": "@tabBarColor",
    "selectedColor": "@tabBarSelectedColor",
    "borderStyle": "@tabBarBorderStyle",
    "backgroundColor": "@tabBarBgColor",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "@tabbarHomeIcon",
        "selectedIconPath": "@tabbarHomeActiveIcon",
        "text": "首页"
      },
      {
        "pagePath": "pages/categories/list/index",
        "iconPath": "@tabbarCategoryIcon",
        "selectedIconPath": "@tabbarCategoryActiveIcon",
        "text": "分类"
      },
      {
        "pagePath": "pages/tags/list/index",
        "iconPath": "@tabbarTagIcon",
        "selectedIconPath": "@tabbarTagActiveIcon",
        "text": "标签"
      },
      {
        "pagePath": "pages/my/index",
        "iconPath": "@tabbarMyIcon",
        "selectedIconPath": "@tabbarMyActiveIcon",
        "text": "关于"
      }
    ]
  }
}
