{
  "pages": [
    //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "首页",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/categories/list/index",
      "style": {
        "navigationBarTitleText": "分类"
      }
    },
    {
      "path": "pages/categories/info/index",
      "style": {
        "navigationBarTitleText": "详情"
      }
    },
    {
      "path": "pages/tags/list/index",
      "style": {
        "navigationBarTitleText": "标签"
      }
    },
    {
      "path": "pages/my/index",
      "style": {
        "navigationBarTitleText": "关于"
      }
    },
    {
      "path": "pages/blogs/index",
      "style": {
        "navigationBarTitleText": "博客列表",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/blog-view/index",
      "style": {
        "navigationBarTitleText": "博客详情",
        "mp-weixin": {
          "usingComponents": {
            "towxml": "/static/towxml/towxml"
          }
        }
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "uni-app",
    "navigationBarBackgroundColor": "#F8F8F8",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#7A7E83",
    "selectedColor": "#000000",
    "borderStyle": "black",
    "backgroundColor": "#ffffff",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/image/tabbar_img/home.png",
        "selectedIconPath": "static/image/tabbar_img/home_active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/categories/list/index",
        "iconPath": "static/image/tabbar_img/category.png",
        "selectedIconPath": "static/image/tabbar_img/category_active.png",
        "text": "分类"
      },
      {
        "pagePath": "pages/tags/list/index",
        "iconPath": "static/image/tabbar_img/tag.png",
        "selectedIconPath": "static/image/tabbar_img/tag_active.png",
        "text": "标签"
      },
      {
        "pagePath": "pages/my/index",
        "iconPath": "static/image/tabbar_img/my.png",
        "selectedIconPath": "static/image/tabbar_img/my_active.png",
        "text": "关于"
      }
    ]
  }
}
